FROM gradle:8.5-jdk17 AS jar-builder
WORKDIR /builder

COPY build.gradle .
RUN gradle copyDependencies --no-daemon

FROM apache/airflow:3.1.2-python3.11

USER root

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends openjdk-17-jre-headless procps && \
    ln -s /usr/lib/jvm/java-17-openjdk-$(dpkg --print-architecture) /usr/lib/jvm/java-17-home

ENV JAVA_HOME=/usr/lib/jvm/java-17-home
ENV PATH="$JAVA_HOME/bin:$PATH"

COPY --from=jar-builder --chown=airflow:0 /builder/build/deps/*.jar /opt/airflow/jars/

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

USER airflow
WORKDIR /opt/airflow

COPY --chown=airflow:0 pyproject.toml uv.lock ./

RUN --mount=type=cache,target=/home/airflow/.cache/uv \
    uv pip install --no-cache-dir -r pyproject.toml
